# ============================================
# TRADING MODE
# ============================================
# Set to 'true' for testnet (safe testing with fake money)
# Set to 'false' for LIVE trading (REAL MONEY - USE WITH CAUTION!)
BINANCE_TESTNET=true

# ============================================
# TESTNET CONFIGURATION (for testing only)
# ============================================
# Get testnet keys from: https://testnet.binance.vision/
# NOTE: These keys ONLY work on testnet, NOT on live Binance
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# ============================================
# LIVE CONFIGURATION (UNCOMMENT TO USE LIVE)
# ============================================
# ⚠️  WARNING: These are for REAL trading with REAL money!
# Get live keys from: https://www.binance.com/en/my/settings/api-management
# NOTE: Live keys are DIFFERENT from testnet keys - you need separate keys!
# 
# To switch to live trading:
# 1. Comment out the testnet keys above
# 2. Uncomment the lines below
# 3. Add your LIVE API keys from Binance.com (NOT testnet.binance.vision)
# 4. Set BINANCE_TESTNET=false
#
# BINANCE_TESTNET=false
# BINANCE_API_KEY=your_live_api_key_here
# BINANCE_API_SECRET=your_live_api_secret_here

# ============================================
# STRATEGY CONFIGURATION
# ============================================
# Minimum profit percentage required (after fees)
MIN_SPREAD_PERCENT=0.03

# Minimum 24h trading volume in USDT (filters low-liquidity pairs)
MIN_LIQUIDITY_24H=1000000

# Maximum position size as percentage of total capital
# Recommended: 5% for live, can be higher for testnet
MAX_POSITION_PERCENT=5

# ============================================
# RISK MANAGEMENT
# ============================================
# Maximum number of simultaneous trades
MAX_CONCURRENT_TRADES=3

# Stop loss percentage (not yet implemented)
STOP_LOSS_PERCENT=1

# Number of consecutive losses before pausing (not yet implemented)
CONSECUTIVE_LOSS_LIMIT=3

# ============================================
# EXECUTION SETTINGS
# ============================================
# Timeout for order execution (milliseconds)
ORDER_TIMEOUT_MS=5000

# Price refresh interval (milliseconds)
PRICE_REFRESH_MS=100

# ============================================
# DASHBOARD (not yet implemented)
# ============================================
DASHBOARD_PORT=3000

# ============================================
# LOGGING
# ============================================
# Log level: error, warn, info, debug
LOG_LEVEL=info
